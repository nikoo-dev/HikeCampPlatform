@page "/tours/{TourId:int}"
@inject HttpClient Http
@inject HikeCampPlatform.Web.Services.AuthState AuthState
@inject IJSRuntime JS

@if (isLoading)
{
    <LoadingState Message="Loading tour details..." />
}
else if (tour == null)
{
    <EmptyState Message="Tour not found." />
}
else
{
    <div class="breadcrumb font-mono">@tour.Country @(string.IsNullOrEmpty(tour.Region) ? "" : $"/ {tour.Region}")</div>
    <h1>@tour.Title</h1>
    <p style="color: var(--sage-light); margin-bottom: 1rem;">Operated by @tour.OperatorCompanyName</p>

    <div class="signpost">
        <div class="signpost-item">
            <div class="signpost-label">Duration</div>
            <div class="signpost-value">@tour.DurationDays days</div>
        </div>
        <div class="signpost-item">
            <div class="signpost-label">Difficulty</div>
            <div class="signpost-value">@DifficultyName(tour.DifficultyLevel)</div>
        </div>
        <div class="signpost-item">
            <div class="signpost-label">Price</div>
            <div class="signpost-value">@tour.PricePerPerson.ToString("0") @tour.Currency</div>
        </div>
        <div class="signpost-item">
            <div class="signpost-label">Type</div>
            <div class="signpost-value">@TypeName(tour.Type)</div>
        </div>
    </div>

    <div id="map" class="trail-map" style="margin-bottom: 2rem;"></div>

    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 2.5rem;">
        <div>
            <div class="section-label">About this trek</div>
            <p style="opacity: 0.9;">@tour.Description</p>
        </div>

        <div class="booking-card">

            @if (paymentStage == PaymentStage.SelectingDeparture)
            {
                <div class="section-label">Departures</div>

                @if (departures == null || departures.Count == 0)
                {
                    <p style="font-size: 0.85rem; color: var(--sage-light);">No upcoming departures.</p>
                }
                else
                {
                    @foreach (var d in departures)
                    {
                        var isSelected = selectedDepartureId == d.Id;
                        <div class="departure-option @(isSelected ? "departure-option-selected" : "")"
                             @onclick="() => SelectDeparture(d.Id)">
                            <div>
                                <div class="font-mono departure-date">@d.DepartureDate.ToString("yyyy-MM-dd")</div>
                                <div class="departure-spots">@d.SpotsRemaining spots left</div>
                            </div>
                            @if (isSelected)
                            {
                                <span class="departure-check">&#10003;</span>
                            }
                        </div>
                    }
                }

                @if (!AuthState.IsLoggedIn)
                {
                    <p style="font-size: 0.85rem; margin-top: 1rem;"><a href="/login">Log in</a> to book.</p>
                }

                @if (selectedDepartureId.HasValue)
                {
                    <div class="booking-confirm">
                        <label class="filter-label">Participants</label>
                        <input type="number" min="1" @bind="numberOfParticipants" class="auth-input" style="margin-bottom: 0.85rem;" />

                        <div class="booking-total">
                            <span>Total</span>
                            <span class="font-mono booking-total-value">@((tour!.PricePerPerson * numberOfParticipants).ToString("0.00")) @tour.Currency</span>
                        </div>

                        <button class="btn-trail" style="width: 100%; margin-top: 0.85rem;" @onclick="SubmitBooking" disabled="@isBooking">
                            @(isBooking ? "Creating booking..." : "Continue to payment")
                        </button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p style="margin-top: 1rem; color: #D88; font-size: 0.85rem;">@errorMessage</p>
                }
            }
            else if (paymentStage == PaymentStage.AwaitingPayment)
            {
                <div class="section-label">Payment</div>
                <p style="font-size: 0.85rem; color: var(--sage-light); margin-bottom: 1rem;">
                    Booking total: <span class="font-mono" style="color: var(--trail-gold);">@bookingResult!.TotalPrice.ToString("0.00") @tour.Currency</span>
                </p>

                <div id="payment-element" style="margin-bottom: 1rem;"></div>

                <button class="btn-trail" style="width: 100%;" @onclick="HandleConfirmPayment" disabled="@isPaying">
                    @(isPaying ? "Processing..." : "Pay now")
                </button>

                <p style="font-size: 0.72rem; color: var(--sage-light); margin-top: 0.75rem;">
                    Test mode -- use card number 4242 4242 4242 4242, any future expiry, any CVC.
                </p>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p style="margin-top: 1rem; color: #D88; font-size: 0.85rem;">@errorMessage</p>
                }
            }
            else if (paymentStage == PaymentStage.Paid)
            {
                <div class="booking-success">
                    Payment successful. Your booking is confirmed -- enjoy the trail.
                </div>
                <button class="btn-trail" style="width: 100%; margin-top: 1rem;" @onclick="ResetBookingFlow">
                    Book another departure
                </button>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public int TourId { get; set; }

    private enum PaymentStage { SelectingDeparture, AwaitingPayment, Paid }

    private TourResponse? tour;
    private List<DepartureResponse>? departures;
    private bool isLoading = true;
    private bool isBooking = false;
    private bool isPaying = false;
    private int? selectedDepartureId;
    private int numberOfParticipants = 1;
    private BookingResponse? bookingResult;
    private string? errorMessage;
    private bool mapInitialized = false;
    private bool stripeInitialized = false;
    private PaymentStage paymentStage = PaymentStage.SelectingDeparture;

    private const string StripePublishableKey = "pk_test_51TlSjy4EMt1abVL6vbUb41TY76h48jgkBtYDeIqFaMfppFEfnx8p4PmhevRACrnJ8LMPMJXq2W88Zy4TdoqiQcwD00rmDJLJBc";

    public class RoutePoint
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public int SequenceOrder { get; set; }
        public string? Label { get; set; }
    }

    public class TourResponse
    {
        public int Id { get; set; }
        public string OperatorCompanyName { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int Type { get; set; }
        public string Country { get; set; } = string.Empty;
        public string? Region { get; set; }
        public int DifficultyLevel { get; set; }
        public decimal PricePerPerson { get; set; }
        public string Currency { get; set; } = string.Empty;
        public int DurationDays { get; set; }
        public List<RoutePoint> RoutePoints { get; set; } = new();
    }

    public class DepartureResponse
    {
        public int Id { get; set; }
        public DateTime DepartureDate { get; set; }
        public int SpotsRemaining { get; set; }
    }

    public class BookingResponse
    {
        public int Id { get; set; }
        public decimal TotalPrice { get; set; }
        public string ClientSecret { get; set; } = string.Empty;
    }

    private string DifficultyName(int level) => level switch
    {
        0 => "Easy", 1 => "Moderate", 2 => "Hard", 3 => "Extreme", _ => "Unknown"
    };

    private string TypeName(int type) => type switch
    {
        0 => "Hiking", 1 => "Camping", 2 => "Trekking", 3 => "Climbing", _ => "Other"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            tour = await Http.GetFromJsonAsync<TourResponse>($"/api/tours/{TourId}");
            departures = await Http.GetFromJsonAsync<List<DepartureResponse>>($"/api/tours/{TourId}/departures");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading tour: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (tour != null && tour.RoutePoints.Count > 0 && !mapInitialized)
        {
            mapInitialized = true;
            var points = tour.RoutePoints
                .OrderBy(p => p.SequenceOrder)
                .Select(p => new { lat = p.Latitude, lng = p.Longitude, label = p.Label })
                .ToArray();

            await JS.InvokeVoidAsync("trailMap.render", "map", points);
        }

        if (paymentStage == PaymentStage.AwaitingPayment && bookingResult != null)
        {
            if (!stripeInitialized)
            {
                stripeInitialized = true;
                await JS.InvokeVoidAsync("stripeCheckout.init", StripePublishableKey);
                await JS.InvokeVoidAsync("stripeCheckout.mountPaymentElement", bookingResult.ClientSecret, "payment-element");
            }
        }
    }

    private void SelectDeparture(int departureId)
    {
        selectedDepartureId = departureId;
        errorMessage = null;
    }

    private async Task SubmitBooking()
    {
        if (!selectedDepartureId.HasValue) return;

        isBooking = true;
        errorMessage = null;

        try
        {
            var request = new { TourDepartureId = selectedDepartureId.Value, NumberOfParticipants = numberOfParticipants };
            var response = await Http.PostAsJsonAsync("/api/bookings", request);

            if (response.IsSuccessStatusCode)
            {
                bookingResult = await response.Content.ReadFromJsonAsync<BookingResponse>();
                paymentStage = PaymentStage.AwaitingPayment;
                stripeInitialized = false;
            }
            else
            {
                errorMessage = "Booking failed: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isBooking = false;
        }
    }

    private async Task HandleConfirmPayment()
    {
        isPaying = true;
        errorMessage = null;

        try
        {
            var result = await JS.InvokeAsync<PaymentResult>("stripeCheckout.confirmPayment", $"{GetBaseUrl()}/tours/{TourId}");

            if (result.success)
            {
                paymentStage = PaymentStage.Paid;
            }
            else
            {
                errorMessage = result.message ?? "Payment failed.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Payment error: {ex.Message}";
        }
        finally
        {
            isPaying = false;
        }
    }

    private string GetBaseUrl()
    {
        return "http://localhost:5095";
    }

    private void ResetBookingFlow()
    {
        paymentStage = PaymentStage.SelectingDeparture;
        selectedDepartureId = null;
        bookingResult = null;
        stripeInitialized = false;
        numberOfParticipants = 1;
    }

    public class PaymentResult
    {
        public bool success { get; set; }
        public string? message { get; set; }
    }
}