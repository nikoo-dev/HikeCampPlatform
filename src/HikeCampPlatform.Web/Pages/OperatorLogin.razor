@page "/operator/login"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject HikeCampPlatform.Web.Services.AuthState AuthState
@inject IJSRuntime JS

<div class="auth-page">
    <div class="breadcrumb">Operator portal</div>
    <h1>Operator log in</h1>

    <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" class="auth-form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <label class="auth-label">Email</label>
        <InputText class="auth-input" @bind-Value="loginModel.Email" />

        <label class="auth-label">Password</label>
        <InputText type="password" class="auth-input" @bind-Value="loginModel.Password" />

        <button type="submit" class="btn-trail" style="width: 100%; margin-top: 0.5rem;" disabled="@isLoading">
            @(isLoading ? "Logging in..." : "Log in")
        </button>
    </EditForm>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p class="auth-error">@errorMessage</p>
    }

    <p class="auth-switch">New operator? <a href="/operator/register">Register here</a></p>
    <p class="auth-switch">Looking to book a tour? <a href="/login">User login</a></p>
</div>

@code {
    private LoginModel loginModel = new();
    private bool isLoading = false;
    private string? errorMessage;

    public class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    public class OperatorAuthResponse
    {
        public string Token { get; set; } = string.Empty;
        public int OperatorId { get; set; }
        public string CompanyName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public bool IsVerified { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.IsLoggedIn)
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm",
                $"You're currently logged in as {AuthState.FullName}. Continuing will log you out. Continue?");

            if (confirmed)
            {
                await AuthState.LogoutAsync();
                AuthState.ApplyAuthHeader(Http);
            }
            else
            {
                Navigation.NavigateTo("/");
            }
        }
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("/api/operator-auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<OperatorAuthResponse>();
                if (result != null)
                {
                    await AuthState.SetUserAsync(result.Token, result.OperatorId, result.CompanyName, "Operator");
                    AuthState.ApplyAuthHeader(Http);
                    Navigation.NavigateTo("/operator/dashboard");
                }
            }
            else
            {
                errorMessage = "Invalid email or password.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}