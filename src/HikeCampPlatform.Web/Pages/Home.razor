@page "/"
@using System.Net.Http.Json
@inject HttpClient Http

<div class="hero">
    <div class="hero-eyebrow font-mono">Hike. Camp. Compete.</div>
    <h1 class="hero-title">Find your next trail,<br />anywhere in the world.</h1>
    <p class="hero-sub">Book verified hiking and camping tours, track your completions, and climb the leaderboard.</p>
    <a href="/tours" class="btn-trail">Browse tours</a>
</div>

<section class="home-section">
    <div class="section-label">Featured tours</div>
    @if (isLoadingTours)
    {
        <p style="color: var(--sage-light);">Loading...</p>
    }
    else if (featuredTours == null || featuredTours.Count == 0)
    {
        <p style="color: var(--sage-light);">No published tours yet.</p>
    }
    else
    {
        <div class="tour-grid">
            @foreach (var tour in featuredTours)
            {
                <a href="/tours/@tour.Id" class="tour-card">
                    <div class="tour-card-type font-mono">@TypeName(tour.Type)</div>
                    <h3>@tour.Title</h3>
                    <div class="tour-card-location font-mono">@tour.Country @(string.IsNullOrEmpty(tour.Region) ? "" : $"/ {tour.Region}")</div>
                    <div class="tour-card-footer">
                        <span class="tour-card-price">@tour.PricePerPerson.ToString("0") <span class="font-mono">@tour.Currency</span></span>
                        <span class="tour-card-difficulty">@DifficultyName(tour.DifficultyLevel)</span>
                    </div>
                </a>
            }
        </div>
    }
</section>

<section class="home-section">
    <div class="section-label">Top of the leaderboard</div>
    @if (isLoadingLeaderboard)
    {
        <p style="color: var(--sage-light);">Loading...</p>
    }
    else if (topEntries == null || topEntries.Count == 0)
    {
        <p style="color: var(--sage-light);">No completions yet -- be the first.</p>
    }
    else
    {
        <div class="leaderboard-list">
            @foreach (var entry in topEntries)
            {
                <div class="leaderboard-row leaderboard-row-top">
                    <div class="leaderboard-rank font-mono">#@entry.Rank</div>
                    <div class="leaderboard-name">@entry.FullName</div>
                    <div class="leaderboard-count">
                        <span class="font-mono">@entry.CompletedTourCount</span>
                        <span class="leaderboard-count-label">completed</span>
                    </div>
                </div>
            }
        </div>
        <a href="/leaderboard" class="trail-link" style="display: inline-block; margin-top: 1rem;">View full leaderboard &rarr;</a>
    }
</section>

@code {
    private List<TourResponse>? featuredTours;
    private List<LeaderboardEntry>? topEntries;
    private bool isLoadingTours = true;
    private bool isLoadingLeaderboard = true;

    public class TourResponse
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public int Type { get; set; }
        public string Country { get; set; } = string.Empty;
        public string? Region { get; set; }
        public int DifficultyLevel { get; set; }
        public decimal PricePerPerson { get; set; }
        public string Currency { get; set; } = string.Empty;
    }

    public class LeaderboardEntry
    {
        public string FullName { get; set; } = string.Empty;
        public int CompletedTourCount { get; set; }
        public int Rank { get; set; }
    }

    private string DifficultyName(int level) => level switch
    {
        0 => "Easy", 1 => "Moderate", 2 => "Hard", 3 => "Extreme", _ => "Unknown"
    };

    private string TypeName(int type) => type switch
    {
        0 => "Hiking", 1 => "Camping", 2 => "Trekking", 3 => "Climbing", _ => "Other"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var allTours = await Http.GetFromJsonAsync<List<TourResponse>>("/api/tours");
            featuredTours = allTours?.Take(3).ToList();
        }
        finally
        {
            isLoadingTours = false;
        }

        try
        {
            var allEntries = await Http.GetFromJsonAsync<List<LeaderboardEntry>>("/api/leaderboard");
            topEntries = allEntries?.Take(3).ToList();
        }
        finally
        {
            isLoadingLeaderboard = false;
        }
    }
}