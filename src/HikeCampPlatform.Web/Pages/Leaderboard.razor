@page "/leaderboard"
@inject HttpClient Http
@inject HikeCampPlatform.Web.Services.AuthState AuthState

<div class="breadcrumb">Standings</div>
<h1>Leaderboard</h1>
<p style="color: var(--sage-light); margin-bottom: 1.5rem;">Ranked by verified, operator-confirmed completions.</p>

@if (isLoading)
{
    <LoadingState Message="Loading leaderboard..." />
}
else if (entries == null || entries.Count == 0)
{
    <EmptyState Message="No completed tours yet. Be the first!" />
}
else
{
    @if (AuthState.IsLoggedIn && myEntry == null)
    {
        <div class="you-not-ranked">You haven't completed any verified tours yet. <a href="/tours">Browse tours</a> to get started.</div>
    }

    <div class="leaderboard-list">
        @foreach (var entry in entries)
        {
            var isMe = AuthState.IsLoggedIn && entry.UserId == AuthState.UserId;
            <div class="leaderboard-row @(entry.Rank <= 3 ? "leaderboard-row-top" : "") @(isMe ? "leaderboard-row-me" : "")">
                <div class="leaderboard-rank font-mono">#@entry.Rank</div>
                <div class="leaderboard-name">
                    @entry.FullName
                    @if (isMe)
                    {
                        <span class="you-badge font-mono">YOU</span>
                    }
                </div>
                <div class="leaderboard-count">
                    <span class="font-mono">@entry.CompletedTourCount</span>
                    <span class="leaderboard-count-label">completed</span>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<LeaderboardEntry>? entries;
    private bool isLoading = true;

    private LeaderboardEntry? myEntry =>
        AuthState.IsLoggedIn ? entries?.FirstOrDefault(e => e.UserId == AuthState.UserId) : null;

    public class LeaderboardEntry
    {
        public int UserId { get; set; }
        public string FullName { get; set; } = string.Empty;
        public int CompletedTourCount { get; set; }
        public int Rank { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            entries = await Http.GetFromJsonAsync<List<LeaderboardEntry>>("/api/leaderboard");
        }
        finally
        {
            isLoading = false;
        }
    }
}