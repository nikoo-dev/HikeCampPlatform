@page "/leaderboard"
@using System.Net.Http.Json
@inject HttpClient Http

<div class="breadcrumb">Standings</div>
<h1>Leaderboard</h1>
<p style="color: var(--sage-light); margin-bottom: 1.5rem;">Ranked by verified, operator-confirmed completions.</p>

@if (isLoading)
{
    <p style="color: var(--sage-light);">Loading leaderboard...</p>
}
else if (entries == null || entries.Count == 0)
{
    <p style="color: var(--sage-light);">No completed tours yet. Be the first!</p>
}
else
{
    <div class="leaderboard-list">
        @foreach (var entry in entries)
        {
            <div class="leaderboard-row @(entry.Rank <= 3 ? "leaderboard-row-top" : "")">
                <div class="leaderboard-rank font-mono">#@entry.Rank</div>
                <div class="leaderboard-name">@entry.FullName</div>
                <div class="leaderboard-count">
                    <span class="font-mono">@entry.CompletedTourCount</span>
                    <span class="leaderboard-count-label">completed</span>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<LeaderboardEntry>? entries;
    private bool isLoading = true;

    public class LeaderboardEntry
    {
        public int UserId { get; set; }
        public string FullName { get; set; } = string.Empty;
        public int CompletedTourCount { get; set; }
        public int Rank { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            entries = await Http.GetFromJsonAsync<List<LeaderboardEntry>>("/api/leaderboard");
        }
        finally
        {
            isLoading = false;
        }
    }
}