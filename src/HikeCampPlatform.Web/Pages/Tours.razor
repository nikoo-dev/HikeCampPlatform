@page "/tours"
@using System.Net.Http.Json
@inject HttpClient Http

<div class="breadcrumb">Browse</div>
<h1>Tours worldwide</h1>

@if (isLoading)
{
    <p style="color: var(--sage-light);">Loading tours...</p>
}
else if (tours == null || tours.Count == 0)
{
    <p style="color: var(--sage-light);">No published tours yet.</p>
}
else
{
    <div class="tour-grid">
        @foreach (var tour in tours)
        {
            <a href="/tours/@tour.Id" class="tour-card">
                <div class="tour-card-type font-mono">@TypeName(tour.Type)</div>
                <h3>@tour.Title</h3>
                <div class="tour-card-location font-mono">@tour.Country @(string.IsNullOrEmpty(tour.Region) ? "" : $"/ {tour.Region}")</div>
                <p class="tour-card-desc">@Truncate(tour.Description, 110)</p>
                <div class="tour-card-footer">
                    <span class="tour-card-price">@tour.PricePerPerson.ToString("0") <span class="font-mono">@tour.Currency</span></span>
                    <span class="tour-card-difficulty">@DifficultyName(tour.DifficultyLevel)</span>
                </div>
            </a>
        }
    </div>
}

@code {
    private List<TourResponse>? tours;
    private bool isLoading = true;

    public class TourResponse
    {
        public int Id { get; set; }
        public string OperatorCompanyName { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int Type { get; set; }
        public string Country { get; set; } = string.Empty;
        public string? Region { get; set; }
        public int DifficultyLevel { get; set; }
        public int DurationDays { get; set; }
        public decimal PricePerPerson { get; set; }
        public string Currency { get; set; } = string.Empty;
    }

    private string DifficultyName(int level) => level switch
    {
        0 => "Easy", 1 => "Moderate", 2 => "Hard", 3 => "Extreme", _ => "Unknown"
    };

    private string TypeName(int type) => type switch
    {
        0 => "Hiking", 1 => "Camping", 2 => "Trekking", 3 => "Climbing", _ => "Other"
    };

    private string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text.Substring(0, maxLength).TrimEnd() + "...";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            tours = await Http.GetFromJsonAsync<List<TourResponse>>("/api/tours");
        }
        finally
        {
            isLoading = false;
        }
    }
}