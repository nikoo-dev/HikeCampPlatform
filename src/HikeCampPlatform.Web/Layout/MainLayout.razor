@inherits LayoutComponentBase
@inject HikeCampPlatform.Web.Services.AuthState AuthState
@inject HttpClient Http

<div class="trail-page">
    <NavMenu />
    <main class="trail-main">
        @Body
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthState.LoadFromStorageAsync();
        AuthState.ApplyAuthHeader(Http);
    }
}