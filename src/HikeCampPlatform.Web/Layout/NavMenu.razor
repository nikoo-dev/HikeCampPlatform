@inject HikeCampPlatform.Web.Services.AuthState AuthState
@inject IJSRuntime JS
@inject HttpClient Http
@implements IDisposable

<div class="trail-nav">
    <div class="trail-nav-brand">HikeCamp</div>

    <nav class="trail-nav-links">
        <NavLink class="trail-link" href="" Match="NavLinkMatch.All">Home</NavLink>
        <NavLink class="trail-link" href="tours">Browse Tours</NavLink>
        <NavLink class="trail-link" href="leaderboard">Leaderboard</NavLink>
    </nav>

    <div class="trail-nav-spacer"></div>

    @if (AuthState.IsLoggedIn)
    {
        <span class="trail-nav-user font-mono">@AuthState.FullName</span>
        <a href="#" class="trail-link" @onclick="HandleLogout" @onclick:preventDefault>Logout</a>
    }
    else
    {
        <NavLink class="trail-link" href="login">Login</NavLink>
        <NavLink class="trail-link trail-link-cta" href="register">Register</NavLink>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        AuthState.OnChange += StateHasChanged;
    }

    private async Task HandleLogout()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to log out?");
        if (confirmed)
        {
            await AuthState.LogoutAsync();
            AuthState.ApplyAuthHeader(Http);
        }
    }

    public void Dispose()
    {
        AuthState.OnChange -= StateHasChanged;
    }
}